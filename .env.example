# Frontend Environment Variables (Next.js)
# Required for auth; must be present when you run `npm run build` (baked into the client bundle).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=

# Backend Environment Variables (Spring Boot)
SERVER_PORT=8080
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
# PPA study fields: join = use table ppa_studyfield (default). column = only studyfield.ppa_id (set SUPABASE_PPA_FIELD_LINK=column).
# SUPABASE_PPA_FIELD_LINK=column
# If useraccount.password is NOT NULL, PPA inserts use this placeholder (real login is Supabase Auth).
# SUPABASE_PPA_USERACCOUNT_PASSWORD_PLACEHOLDER=__SUPABASE_AUTH__
# Send Supabase invite email when university admin creates a PPA (needs SUPABASE_SERVICE_ROLE_KEY + Auth email/SMTP).
# SUPABASE_INVITE_ON_PPA_CREATE=true
# Required for PPA invite redirect (…/auth/set-password). Must be listed under Supabase Auth → URL configuration → Redirect URLs.
# Invite emails use a one-time link (Supabase) to open that page; the PPA then sets a password and logs in with email+password afterward.
FRONTEND_URL=
